# Environment Variables Template
# Copy this file to .env.local and configure for your environment

# API Configuration
# Set this to your backend API base URL
# For production: http://192.168.3.33:5000/api
# For development: http://localhost:5000/api (or your local backend)
REACT_APP_API_URL=http://192.168.3.33:5000/api

# Optional: Debug mode for development
# REACT_APP_DEBUG=true

# Optional: API timeout settings (in milliseconds)
# REACT_APP_API_TIMEOUT=30000
# REACT_APP_UPLOAD_TIMEOUT=120000

# React App Variables (set by create-react-app)
# REACT_APP_VERSION=0.1.0
